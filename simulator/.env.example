# Thiết lập biến môi trường cho Simulator

# OpenWeather API
# Đăng ký miễn phí tại: https://openweathermap.org/api
# Chọn "Current weather data" API (free tier)
OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_CITY=Hanoi
OPENWEATHER_COUNTRY_CODE=VN

# MQTT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC=iot/weather/hanoi
MQTT_CLIENT_ID=weather-simulator

# Tần suất gửi dữ liệu (milliseconds)
# Mặc định: 15000 ms = 15 giây
PUBLISH_INTERVAL=15000

# Logging
LOG_LEVEL=info
